# CafeConnect — root environment (copy to .env and edit).
# Used by docker-compose.yml at the repo root for the Django hub + Postgres + Redis.

# ---------------------------------------------------------------------------
# LAN access for the physical Android device (local Wi-Fi development)
# ---------------------------------------------------------------------------
# Put the HOST machine's Wi-Fi IPv4 address here (the computer running Docker).
#   Windows : run `ipconfig`  -> "IPv4 Address" under your Wi-Fi adapter
#   macOS   : run `ipconfig getifaddr en0`
#   Linux   : run `hostname -I | awk '{print $1}'`
# Example: 192.168.1.42  (leave blank if you only use the Android emulator)
DJANGO_LAN_HOST=192.168.1.42

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# Generate a strong key before any real deployment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-cafeconnect-change-me
DJANGO_DEBUG=true

# If you set DJANGO_ALLOWED_HOSTS explicitly it overrides the compose default.
# Otherwise compose builds it from localhost + DJANGO_LAN_HOST automatically.
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,192.168.1.42
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.42:8000

# CORS is only needed for the browser guest/management web, not the Flutter app.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
DJANGO_CORS_ALLOW_CREDENTIALS=false
DJANGO_TIME_ZONE=Europe/Rome

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=cafeconnect
POSTGRES_USER=cafeconnect
POSTGRES_PASSWORD=cafeconnect
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis (Channels layer for WebSocket fan-out)
# ---------------------------------------------------------------------------
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Host port the hub is published on (http://localhost:WEB_PORT)
# ---------------------------------------------------------------------------
WEB_PORT=8000
