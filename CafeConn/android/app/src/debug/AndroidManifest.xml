<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Debug-only: allow cleartext HTTP so the app can reach the local dev hub
         over Wi-Fi. The manifest merger folds this networkSecurityConfig into the
         app's <application> node for debug builds; release builds are unaffected. -->
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
